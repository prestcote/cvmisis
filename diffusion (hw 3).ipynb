        "class VPConfig:\n",
        "    def __init__(self, schedule='linear', beta_min=0.0001, beta_max=0.02, T=1000):\n",
        "        self.schedule = schedule\n",
        "        self.beta_min = beta_min\n",
        "        self.beta_max = beta_max\n",
        "        self.T = T\n",
        "        self.lr = 1e-3\n",
        "        self.epochs = 2000\n",
        "        self.batch_size = 512\n",
        "        self.hidden_dim = 256\n",
        "        self.data_samples = 5000\n"
      ],
      "metadata": {
        "id": "uEagnXiCsd6Y"
      },
      "execution_count": null,
      "outputs": []
