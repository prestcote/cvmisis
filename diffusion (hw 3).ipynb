        "class Config:\n",
        "    sigma_min = 0.01\n",
        "    sigma_max = 4.0\n",
        "\n",
        "    lr = 1e-3\n",
        "    epochs = 2000\n",
        "    batch_size = 512\n",
        "    hidden_dim = 256\n",
        "    num_timesteps = 1000\n",
        "    data_samples = 5000"
      ],
